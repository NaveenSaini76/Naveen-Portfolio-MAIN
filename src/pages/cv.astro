---
import BaseLayout from "../layouts/BaseLayout.astro";
import TimeLineElement from "../components/cv/TimeLine.astro";
import { highlightTextParts } from "../lib/highlightText";

const profile =
  "B.E. (Hons.) Computer Science and Engineering student specializing in AI/ML. I build end-to-end ML pipelines, run data analysis with Python and SQL, and apply NLP and computer vision techniques to real-world problems.";

const certifications = [
  "Microsoft Certified: Azure AI Fundamentals (AI-900) (Jun 2023)",
  "University of Michigan - Programming for Everybody (Oct 2023)",
  "IBM - Python for Data Science, AI & Development (Mar 2024)",
  "IBM - Predictive Analytics using IBM SPSS Modeler (Nov 2024)",
  "Microsoft - Introduction to Generative AI for Data Analysis (Mar 2025)",
  "Oracle - OCI Generative AI Professional",
  "University of Michigan - Applied Machine Learning in Python",
];

const experiences = [
  {
    title: "AI/ML Project Work",
    subtitle: "2023 to Present | Chandigarh University",
    description:
      "Built ML pipelines for fraud detection, sentiment analysis, and fake news classification using feature engineering, model evaluation, and clear reporting.",
  },
  {
    title: "Data Analytics Projects",
    subtitle: "2023 to Present | Academic Projects",
    description:
      "Delivered customer segmentation and KPI dashboards with SQL, Python, and Power BI for actionable business insights.",
  },
];

const skillGroups = [
  ["Python", "SQL", "C++", "C"],
  ["Scikit-Learn", "Pandas", "NumPy", "Matplotlib", "Seaborn", "OpenCV"],
  ["NLP", "Computer Vision", "Feature Engineering", "Model Evaluation", "EDA"],
  ["Power BI", "Excel", "Jupyter Notebook", "Git", "GitHub", "VS Code"],
  ["Data Structures & Algorithms", "OOP", "Statistical Analysis", "KPI Reporting"],
];
---

<BaseLayout title="Resume" sideBarActiveItemID="cv">
  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Profile</div>
  </div>

  <div class="mb-10 text-justify">
    {highlightTextParts(profile).map((part) =>
      part.kind ? <span class={`focus-${part.kind}`}>{part.text}</span> : part.text
    )}
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Education</div>
  </div>

  <div class="time-line-container grid gap-4 mb-10">
      <TimeLineElement
        title="B.E. Computer Science Engineering (AI & ML)"
        subtitle="2022 to 2026 at Chandigarh University, Chandigarh | CGPA: 6.96"
      />
      <TimeLineElement
        title="Intermediate (HPBOSE)"
        subtitle="79.8%"
      />
      <TimeLineElement
        title="Matriculation (CBSE)"
        subtitle="70.4%"
      />
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Experience</div>
  </div>

  <div class="time-line-container mb-10">
    {experiences.map((experience) => <TimeLineElement {...experience} />)}
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Certifications</div>
  </div>

  <ul class="list-disc mx-6 mb-10 grid gap-2">
    {certifications.map((certification) => (
      <li>
        {highlightTextParts(certification).map((part) =>
          part.kind ? <span class={`focus-${part.kind}`}>{part.text}</span> : part.text
        )}
      </li>
    ))}
  </ul>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Skills</div>
  </div>

  <div class="mb-10 flex flex-wrap gap-3">
    {skillGroups.flat().map((skill) => (
      <span class="focus-chip">
        {highlightTextParts(skill).map((part) =>
          part.kind ? <span class={`focus-${part.kind}`}>{part.text}</span> : part.text
        )}
      </span>
    ))}
  </div>

  <div class="mb-5 mt-10">
    <div class="text-3xl w-full font-bold">Contact</div>
  </div>

  <ul class="list-disc mx-6">
    <li>Email - ns1392676@gmail.com</li>
    <li>WhatsApp - +91 8628996161</li>
    <li>Gmail - mail.google.com/mail/u/0/#inbox</li>
    <li>Location - Kangra, Himachal Pradesh, India</li>
    <li>LinkedIn - linkedin.com/in/naveen-saini-0b3617332</li>
    <li>GitHub - github.com/NaveenSaini76</li>
  </ul>
</BaseLayout>
