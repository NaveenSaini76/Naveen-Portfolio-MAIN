---
import BaseLayout from "../layouts/BaseLayout.astro";
import Project3DCard from "../components/Project3DCard";

const projects = [
  {
    title: "Credit Card Fraud Detection System",
    img: "/project-images/credit-card.png",
    desc: "End-to-end fraud detection on 284,000+ transactions using SMOTE, feature engineering, and XGBoost, reaching 0.98 AUC-ROC.",
    url: "/projects",
    badge: "ML",
  },
  {
    title: "Movie Sentiment & Review Intelligence Analyzer",
    img: "/project-images/movie-sentiment.png",
    desc: "NLP pipeline on 50,000+ IMDb reviews with TF-IDF and Linear SVM, achieving 93.6% accuracy and 93.1% F1-score.",
    url: "/projects",
    badge: "NLP",
  },
  {
    title: "Fake News Detection System",
    img: "/project-images/fake-news.avif",
    desc: "TF-IDF based fake news classifier using Naive Bayes and Logistic Regression with a real-time prediction interface.",
    url: "/projects",
    badge: "ML",
  },
  {
    title: "Retail Sales & Customer Segmentation Analysis",
    img: "/project-images/retail-sales.png",
    desc: "Customer segmentation with RFM and K-Means, plus an interactive Power BI dashboard for revenue and CLV insights.",
    url: "/projects",
    badge: "ANALYTICS",
  },
];
---

<BaseLayout title = "Projects" sideBarActiveItemID="projects">
  <div>
    <div class="text-3xl w-full font-bold mb-5">Projects</div>
  </div>

  <div class="grid gap-6 md:grid-cols-2">
    {projects.map((project) => <Project3DCard client:load {...project} />)}
  </div>
</BaseLayout>
