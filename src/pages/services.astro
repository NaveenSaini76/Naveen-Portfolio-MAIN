---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
---

<BaseLayout title="Focus Areas" sideBarActiveItemID="services">
  <div>
    <div class="text-3xl w-full font-bold mb-5">Focus Areas</div>
  </div>

  <HorizontalCard
    title="Full Stack Development"
    img="/post_img.webp"
    desc="MERN and API-focused development with React.js, Node.js, Express.js, FastAPI, REST APIs, MongoDB, MySQL, and SQLite." 
    badge="SWE"
    url="/cv"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Machine Learning & AI"
    img="/post_img.webp"
    desc="Practical ML systems with Python, Scikit-learn, NumPy, Pandas, NLP, prompt engineering, and generative AI foundations." 
    url="/projects"
    badge="ML"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Cloud, Data & DevOps"
    img="/post_img.webp"
    desc="Cloud and data workflows across Microsoft Azure, GCP BigQuery, Cloud SQL, GitHub, CI/CD, Postman, and Linux/Unix." 
    url="/cv"
    badge="CLOUD"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Problem Solving & Product Thinking"
    img="/post_img.webp"
    desc="Class representative for 60+ students, hackathon top 50 out of 10,000+ teams, and builder of tools with clear user value." 
    url="/cv"
  />
</BaseLayout>
