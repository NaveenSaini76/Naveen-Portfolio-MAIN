---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
---

<BaseLayout title="Focus Areas" sideBarActiveItemID="services">
  <div>
    <div class="text-3xl w-full font-bold mb-5">Focus Areas</div>
  </div>

  <HorizontalCard
    title="Machine Learning & AI"
    img="/project-images/news-classify-project-img.png"
    desc="ML pipelines with feature engineering, model evaluation, and deployment-ready workflows using Python, Scikit-learn, and NLP." 
    badge="ML"
    url="/projects"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Data Analytics & Visualization"
    img="/project-images/money-tracker-img.png"
    desc="Data analysis using Python, SQL, Pandas, and Power BI with clean KPI reporting and data storytelling." 
    url="/cv"
    badge="ANALYTICS"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="NLP & Computer Vision"
    img="/project-images/lecture-capture-project-img.png"
    desc="Text and image modeling with TF-IDF, classical ML, and OpenCV for sentiment, fake news, and vision tasks." 
    url="/projects"
    badge="NLP"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Data Engineering Foundations"
    img="/project-images/rookhide-img.png"
    desc="Reliable data prep, SQL joins, and feature engineering with reproducible notebooks and version control." 
    url="/cv"
  />
</BaseLayout>
