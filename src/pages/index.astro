---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import { highlightTextParts } from "../lib/highlightText";

const intro =
  "B.E. (Hons.) Computer Science and Engineering student specializing in AI/ML at Chandigarh University. Focused on ML pipelines, NLP, computer vision, and data analytics with Python and SQL, delivering clean, actionable insights.";
---

<BaseLayout sideBarActiveItemID="home">
  <div class="pb-12 mt-5">
    <div class="text-xl py-1">Hello</div>
    <div class="text-5xl font-bold">I'm Naveen</div>
    <div class="text-3xl py-3 font-bold">AI/ML & Data Analytics Student</div>
    <div class="py-2">
      <text class="text-lg">
        {highlightTextParts(intro).map((part) =>
          part.kind ? <span class={`focus-${part.kind}`}>{part.text}</span> : part.text
        )}
      </text>
    </div>
    <div class="mt-8">
      <a class="btn" href="https://mail.google.com/mail/u/0/#inbox" target="_blank">Email</a>
      <a href="https://linkedin.com/in/naveen-saini-0b3617332" target="_blank" class="btn btn-outline ml-5">
        Connect on LinkedIn
      </a>
    </div>
  </div>

  <div>
    <div class="text-3xl w-full font-bold mb-2">Featured projects {"</>"}</div>
  </div>

  <HorizontalCard
    title="Credit Card Fraud Detection System"
    img="/project-images/credit-card.png"
    desc="Built an end-to-end fraud detection pipeline on 284,000+ transactions using SMOTE, feature engineering, and XGBoost, achieving 0.98 AUC-ROC."
    url="/projects"
    badge="ML"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Movie Sentiment & Review Intelligence Analyzer"
    img="/project-images/movie-sentiment.png"
    desc="Built a full NLP pipeline on 50,000+ IMDb reviews and achieved 93.6% accuracy with Linear SVM using TF-IDF features."
    url="/projects"
    badge="NLP"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Fake News Detection System"
    img="/project-images/fake-news.avif"
    desc="NLP-driven fake news classifier using TF-IDF with Naive Bayes and Logistic Regression for reliable credibility detection."
    url="/projects"
    badge="ML"
  />
</BaseLayout>
